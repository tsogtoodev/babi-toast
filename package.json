{
	"name": "@tsogtoodev/babi-toast",
	"version": "0.4.2",
	"description": "An opinionated, morphing gooey toast notification library for Vue — a Sonner-style replacement with FLIP morphs, streaming, and promote-to-widget.",
	"author": "Tsogtbayar <tsogtoo.dev@gmail.com>",
	"license": "MIT",
	"keywords": [
		"vue",
		"vue3",
		"toast",
		"notification",
		"sonner",
		"gooey",
		"morph",
		"promote"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tsogtoodev/babi-toast.git"
	},
	"bugs": {
		"url": "https://github.com/tsogtoodev/babi-toast/issues"
	},
	"homepage": "https://github.com/tsogtoodev/babi-toast#readme",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
		"build": "node scripts/build.mjs",
		"dev": "bunchee --watch",
		"demo": "npm run build && node scripts/demo-server.mjs",
		"prepublishOnly": "npm run build && npm test",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"vue": ">=3.3"
	},
	"devDependencies": {
		"@vue/test-utils": "^2.4.10",
		"bunchee": "^6.9.4",
		"jsdom": "^29.1.1",
		"typescript": "^5.9.2",
		"vitest": "^4.1.5",
		"vue": "^3.5.0"
	}
}
