{
	"name": "@tsogtbayar/babi-toast",
	"version": "0.1.0",
	"description": "An opinionated, morphing gooey toast notification library for vue, replacement for sonner.",
	"repository": {
		"type": "git",
		"url": "https://git.bolor.net/tsogtbayar/babi-toast.git"
	},
	"publishConfig": {
		"@tsogtbayar:registry": "https://git.bolor.net/api/v4/projects/844/packages/npm/"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"default": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22",
		"npm": ">=10"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "rm -rf dist && bunchee && cp src/styles.css dist/styles.css",
		"dev": "bunchee --watch",
		"demo": "npm run build && node scripts/demo-server.mjs"
	},
	"peerDependencies": {
		"vue": ">=3.3"
	},
	"devDependencies": {
		"bunchee": "^6.9.4",
		"typescript": "^5.9.2",
		"vue": "^3.5.0"
	}
}
